generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  TIKTOK
  YOUTUBE_SHORTS
  INSTAGRAM_REELS
  FACEBOOK_REELS
  SHOPEE_VIDEO
  LAZADA_VIDEO
}

enum PostStatus {
  DRAFT
  QUEUED
  PUBLISHING
  PUBLISHED
  PARTIAL_PUBLISHED
  FAILED
}

enum PublishStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
}

enum SubscriptionPlan {
  BASIC
  STARTER
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model User {
  id                 String        @id @default(cuid())
  firebaseUid        String        @unique
  email              String        @unique
  displayName        String?
  photoUrl           String?
  posts              Post[]
  templates          Template[]
  subscription       Subscription?
  realClipCaptionUsages RealClipCaptionUsage[]
  aiEditUsages       AiEditUsage[]
  deviceTokens       DeviceToken[]
  socialConnections  SocialConnection[]
  postPeerProfile    PostPeerProfile?
  billingCustomerId  String?       @unique
  monthlyPostCount   Int           @default(0)
  monthlyPostResetAt DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Post {
  id                String            @id @default(cuid())
  userId            String
  caption           String
  videoS3Key        String
  scheduledAt       DateTime?
  publishedAt       DateTime?
  status            PostStatus        @default(DRAFT)
  selectedPlatforms Platform[]
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformPublishes PlatformPublish[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId, createdAt])
  @@index([scheduledAt, status])
}

model PlatformPublish {
  id             String        @id @default(cuid())
  postId         String
  platform       Platform
  status         PublishStatus @default(PENDING)
  externalPostId String?
  views          Int           @default(0)
  likes          Int           @default(0)
  errorMessage   String?
  publishedAt    DateTime?
  post           Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([postId, platform])
  @@index([platform, status])
}

model Template {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String             @unique
  plan                  SubscriptionPlan   @default(BASIC)
  status                SubscriptionStatus @default(ACTIVE)
  billingSubscriptionId String?            @unique
  currentPeriodEnd      DateTime?
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model RealClipCaptionUsage {
  id        String   @id @default(cuid())
  userId    String
  monthKey  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, monthKey])
  @@index([createdAt])
}

model AiEditUsage {
  id        String   @id @default(cuid())
  userId    String
  monthKey  String
  minutes   Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, monthKey])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model SocialConnection {
  id                String   @id @default(cuid())
  userId            String
  platform          Platform
  postPeerAccountId String
  displayName       String?
  externalAccountId String?
  connectedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
}

model PostPeerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  profileId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
